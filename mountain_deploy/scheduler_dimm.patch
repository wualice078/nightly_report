+static void append_eso_dimm_log(const char *fits_name)
+{
+    const char *root;
+    char cmd[768];
+
+    root = getenv("LS4_ROOT");
+    if (root == NULL || root[0] == '\0')
+        return;
+    if (fits_name != NULL && fits_name[0] != '\0')
+        snprintf(cmd, sizeof(cmd),
+            "csh \"%s/bin/append_eso_dimm_log.csh\" \"%s\" >& /dev/null",
+            root, fits_name);
+    else
+        snprintf(cmd, sizeof(cmd),
+            "csh \"%s/bin/append_eso_dimm_log.csh\" >& /dev/null", root);
+    if (system(cmd) == -1)
+        fprintf(stderr, "observe_next_field: append_eso_dimm_log failed\n");
+}
